{
  "name": "sakura-mc-launcher-desktop",
  "version": "0.1.0",
  "description": "樱花MC启动器 - 桌面版 (Electron)",
  "main": "main.js",
  "author": "SakuraMC",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win --x64",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.sakuramc.launcher",
    "productName": "樱花MC启动器",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "web/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "樱花MC启动器-${version}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "樱花MC启动器"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "build",
      "category": "Game"
    }
  }
}
