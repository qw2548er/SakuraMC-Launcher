<?xml version="1.0" encoding="UTF-8"?>
<plugin xmlns="http://apache.org/cordova/ns/plugins/1.0"
        id="cordova-plugin-webview-config"
        version="1.0.0">
    <name>WebViewConfig</name>
    <description>WebView 配置优化</description>
    <license>MIT</license>
    
    <engines>
        <engine name="cordova" version=">=10.0.0" />
    </engines>
    
    <platform name="android">
        <config-file target="config.xml" parent="/*">
            <feature name="WebViewConfig">
                <param name="android-package" value="com.sakuramc.webview.WebViewConfigPlugin" />
                <param name="onload" value="true" />
            </feature>
        </config-file>
        
        <source-file src="src/android/WebViewConfigPlugin.java" target-dir="src/com/sakuramc/webview" />
    </platform>
</plugin>
