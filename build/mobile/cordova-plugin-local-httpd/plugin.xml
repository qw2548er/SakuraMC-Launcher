<?xml version="1.0" encoding="UTF-8"?>
<plugin xmlns="http://apache.org/cordova/ns/plugins/1.0"
        id="cordova-plugin-local-httpd"
        version="1.0.0">
    <name>LocalHttpd</name>
    <description>内置本地HTTP服务器，提供稳定的Web内容加载</description>
    <license>MIT</license>
    
    <engines>
        <engine name="cordova" version=">=10.0.0" />
    </engines>
    
    <platform name="android">
        <config-file target="config.xml" parent="/*">
            <feature name="LocalHttpd">
                <param name="android-package" value="com.sakuramc.httpd.LocalHttpdPlugin" />
            </feature>
        </config-file>
        
        <source-file src="src/android/LocalHttpdPlugin.java" target-dir="src/com/sakuramc/httpd" />
        <source-file src="src/android/NanoHTTPD.java" target-dir="src/com/sakuramc/httpd" />
        
        <js-module src="www/local-httpd.js" name="LocalHttpd">
            <clobbers target="window.LocalHttpd" />
        </js-module>
    </platform>
</plugin>
